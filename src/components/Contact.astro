---
<section data-section="contact" class="py-24 max-w-2xl mx-auto px-4 text-center">
    <div class="mb-16">
        <h2 class="text-xs font-mono uppercase tracking-[0.4em] text-white/40 mb-2">// Secure_Uplink</h2>
        <div class="h-[1px] w-full bg-gradient-to-r from-white/20 to-transparent"></div>
    </div>

    <div class="space-y-12 font-mono">
        <div class="space-y-4">
            <p class="text-sm text-white/60 uppercase tracking-widest">For direct transmissions and collaborative inquiries:</p>
            <a 
                href="mailto:supervoidsociety@gmail.com" 
                class="text-xl md:text-3xl text-white hover:text-white/80 transition-all underline underline-offset-8 decoration-white/20"
            >
                supervoidsociety@gmail.com
            </a>
        </div>

        <div class="pt-8 flex flex-col items-center gap-6">
            <div class="h-[1px] w-12 bg-white/20"></div>
            <a 
                href="https://github.com/supervoid-society" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group flex items-center gap-3 px-8 py-3 border border-white/10 hover:border-white/40 transition-all"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100 transition-opacity"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                <span class="text-xs uppercase tracking-[0.3em]">GitHub_Archive</span>
            </a>
        </div>

        <div class="text-[8px] text-white/20 uppercase tracking-widest pt-12">
            Transmission Protocol: SMTP/TLS-01 // End of Line.
        </div>
    </div>
</section>
