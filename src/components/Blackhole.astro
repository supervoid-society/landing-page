---
---
<div class="blackhole-container relative flex items-center justify-center w-full max-w-[600px] aspect-square mx-auto overflow-hidden">
    <canvas id="blackhole-canvas" class="w-full h-full z-20"></canvas>
    
    <!-- Central Singularity -->
    <div class="absolute inset-[44%] bg-black rounded-full z-40 shadow-[0_0_100px_rgba(255,255,255,0.1)] border border-white/5 pointer-events-none"></div>
    
    <!-- Core Bloom -->
    <div class="absolute inset-[35%] bg-white opacity-[0.05] blur-[80px] rounded-full z-10 pointer-events-none"></div>
</div>

<script>
    class Particle {
        r: number;
        theta: number;
        arm: number;
        speed: number;
        size: number;
        opacity: number;
        w: number;
        h: number;
        x: number = 0;
        y: number = 0;
        px: number = 0;
        py: number = 0;

        constructor(w: number, h: number) {
            this.w = w;
            this.h = h;
            this.reset(true);
        }

        // Gaussian-like random for "wispy" clustering
        gaussianRandom(mean = 0, stdev = 1) {
            const u = 1 - Math.random();
            const v = 1 - Math.random();
            const z = Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
            return z * stdev + mean;
        }

        reset(initial = false) {
            this.arm = Math.floor(Math.random() * 5); // 5 arms for high density
            
            // Logarithmic spiral distribution
            const maxRadius = this.w / 2;
            const minRadius = maxRadius * 0.13; // proportional to singularity size
            
            if (initial) {
                this.r = minRadius + Math.random() * (maxRadius * 0.87);
            } else {
                this.r = maxRadius * 0.93 + Math.random() * (maxRadius * 0.13);
            }

            // The Spiral Math
            const armOffset = (this.arm * Math.PI * 2) / 5;
            const spiralFactor = 0.8; // Tightness
            this.theta = armOffset + (this.r * 0.05 * spiralFactor);
            
            // Add "wispy" spread using Gaussian noise
            // Spread is tighter near the center
            const spread = (this.r / maxRadius) * 0.8;
            this.theta += this.gaussianRandom(0, spread);

            this.speed = (0.5 + Math.random() * 1.5) * (100 / (this.r + 20));
            this.size = 0.5 + Math.random() * 1.2;
            this.opacity = 0.1 + Math.random() * 0.4;
            
            this.updatePos();
            this.px = this.x;
            this.py = this.y;
        }

        updatePos() {
            this.x = (this.w / 2) + Math.cos(this.theta) * this.r;
            this.y = (this.h / 2) + Math.sin(this.theta) * this.r;
        }

        update() {
            this.px = this.x;
            this.py = this.y;

            // Orbit speed
            this.theta += this.speed * 0.015;
            
            // Spiral inward
            // Inward speed increases as it gets closer
            const maxRadius = this.w / 2;
            const inwardPull = 0.2 + (maxRadius * 0.16 / this.r);
            this.r -= inwardPull;

            this.updatePos();

            const singularityRadius = this.w * 0.063; // matches the visual singularity
            if (this.r < singularityRadius) {
                this.reset();
            }
        }

        draw(ctx: CanvasRenderingContext2D) {
            // Brighter near core
            const shade = Math.floor(180 + (1 - this.r / 300) * 75);
            ctx.strokeStyle = `rgba(${shade}, ${shade}, ${shade}, ${this.opacity})`;
            ctx.lineWidth = this.size;
            
            ctx.beginPath();
            ctx.moveTo(this.px, this.py);
            ctx.lineTo(this.x, this.y);
            ctx.stroke();
        }
    }

    function init() {
        const canvas = document.getElementById('blackhole-canvas') as HTMLCanvasElement;
        if (!canvas) return;

        const ctx = canvas.getContext('2d', { alpha: false });
        if (!ctx) return;

        let w: number, h: number;
        const resize = () => {
            const dpr = window.devicePixelRatio || 1;
            w = canvas.width = canvas.offsetWidth * dpr;
            h = canvas.height = canvas.offsetHeight * dpr;
            ctx.scale(dpr, dpr);
            w = canvas.offsetWidth;
            h = canvas.offsetHeight;
        };

        resize();
        window.addEventListener('resize', resize);

        const particles: Particle[] = [];
        const isMobile = window.innerWidth < 768;
        const count = isMobile ? 3000 : 8000; 

        for (let i = 0; i < count; i++) {
            particles.push(new Particle(w, h));
        }

        function loop() {
            // Persistent motion blur
            ctx.fillStyle = '#050505';
            ctx.globalAlpha = 0.15;
            ctx.fillRect(0, 0, w, h);
            ctx.globalAlpha = 1.0;

            particles.forEach(p => {
                p.update();
                p.draw(ctx);
            });

            requestAnimationFrame(loop);
        }

        loop();
    }

    init();
</script>

<style>
    .blackhole-container {
        filter: contrast(1.3) brightness(1.2);
    }
    
    #blackhole-canvas {
        /* Merge particles into a wispy fog */
        filter: blur(0.6px);
    }
</style>
